# =============================================================================
# Allturf CRM — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local — it is listed in .gitignore.
# =============================================================================

# ---------------------------------------------------------------------------
# Supabase — Database & Auth
# ---------------------------------------------------------------------------
# Get these from: https://supabase.com/dashboard/project/_/settings/api

# Public URL for your Supabase project (exposed to browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Public anonymous key (exposed to browser, safe for client-side use with RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# Service role key (server-side only, bypasses RLS — KEEP SECRET)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# ---------------------------------------------------------------------------
# LLM Provider — AI Consultation Engine
# ---------------------------------------------------------------------------

# Groq API key for llama-3.3-70b-versatile
# Get from: https://console.groq.com/keys
GROQ_API_KEY=gsk_...

# Optional: override the default Groq model
# GROQ_MODEL=llama-3.3-70b-versatile

# Which LLM provider to use by default. Currently only "groq" is supported.
DEFAULT_LLM_PROVIDER=groq

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------

# Public-facing URL of the deployed app (used for CORS, callbacks, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# CLI / Skills Authentication (optional)
# ---------------------------------------------------------------------------

# Bearer token for authenticating Claude Code skills and CLI helper
# against /api/v1/ routes. Generate a random string.
# Only needed if using the CLI helper (scripts/crm-api.ts)
# PROJECT_SYNC_API_KEY=your-random-secret-here

# ---------------------------------------------------------------------------
# Future — Not yet active
# ---------------------------------------------------------------------------

# Anthropic API key for Claude provider (dual LLM support planned)
# ANTHROPIC_API_KEY=sk-ant-...
